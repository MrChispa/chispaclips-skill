# =====================================================================
#  ChispaClips-Skill · Configuración de variables de entorno
#  BrainMatic — https://github.com/brainmatic/chispaclips-skill
# =====================================================================
#
#  Copia este archivo a `.env` y rellena los valores.
#  NUNCA subas `.env` al repositorio (ya está en `.gitignore`).
#

# ---------------------------------------------------------------------
# Selección de proveedor LLM
# ---------------------------------------------------------------------
# Opciones: gemini | claude | openai
# - gemini:    Google Gemini (multimodal nativo, recomendado)
# - claude:    Anthropic Claude (requiere extraer frames del video)
# - openai:    OpenAI, OpenRouter, OpenCode o cualquier API OpenAI-compatible
LLM_PROVIDER=gemini

# ---------------------------------------------------------------------
# Proveedor: Gemini
# ---------------------------------------------------------------------
# Obtén tu clave gratis en: https://aistudio.google.com/apikey
GEMINI_API_KEY=tu_clave_de_gemini_aqui
GEMINI_MODEL=gemini-3-flash-preview

# ---------------------------------------------------------------------
# Proveedor: Claude (Anthropic)
# ---------------------------------------------------------------------
# Obtén tu clave en: https://console.anthropic.com/
ANTHROPIC_API_KEY=tu_clave_de_anthropic_aqui
CLAUDE_MODEL=claude-3-5-sonnet-latest

# ---------------------------------------------------------------------
# Proveedor: OpenAI / OpenRouter / OpenCode (API OpenAI-compatible)
# ---------------------------------------------------------------------
# - OpenAI nativo:      https://api.openai.com/v1
# - OpenRouter:         https://openrouter.ai/api/v1
# - OpenCode local:     http://localhost:8080/v1
OPENAI_API_KEY=tu_clave_de_openai_aqui
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

# ---------------------------------------------------------------------
# Upload-Post (publicación en TikTok / Instagram / YouTube)
# ---------------------------------------------------------------------
# 1. Regístrate gratis en: https://upload-post.com
# 2. Conecta tus redes sociales en: https://app.upload-post.com
# 3. Crea un "profile" en Manage Users (su nombre va aquí, NO tu @handle)
# 4. Genera una API key en Settings
UPLOAD_POST_API_KEY=tu_clave_de_upload_post
UPLOAD_POST_PROFILE=nombre_de_tu_profile

# ---------------------------------------------------------------------
# Carpetas de trabajo (rutas absolutas)
# ---------------------------------------------------------------------
# Por defecto se usan <repo>/.chispaclips/input y <repo>/.chispaclips/output
INPUT_FOLDER=/ruta/absoluta/a/tus/videos/largos
OUTPUT_FOLDER=/ruta/absoluta/donde/guardar/clips

# ---------------------------------------------------------------------
# Configuración regional
# ---------------------------------------------------------------------
# Zona horaria para programaciones (formato IANA)
# América: America/Bogota, America/Mexico_City, America/Buenos_Aires, America/Lima, America/Santiago
# España:  Europe/Madrid
# UTC:     UTC
TIMEZONE=America/Bogota

# ---------------------------------------------------------------------
# Proveedor de transcripción
# ---------------------------------------------------------------------
# Opciones: whisper | groq
# - whisper: corre `faster-whisper` en tu CPU. Privado, gratis, primera vez
#   descarga el modelo (~1.5 GB para medium). Más lento.
# - groq:    usa la API de Groq (Whisper large-v3 en la nube). Mucho más
#   rápido (un video de 10 min se transcribe en ~10s vs ~5min de local).
#   Requiere GROQ_API_KEY. Tier gratuito generoso.
TRANSCRIBER_PROVIDER=whisper

# Modelo de Whisper LOCAL (solo aplica si TRANSCRIBER_PROVIDER=whisper).
# Opciones: tiny | base | small | medium | large-v3
# medium = equilibrio entre velocidad y precisión (por defecto)
# small  = el doble de rápido pero pierde vocabulario técnico
# large-v3 = más preciso, ~3× más lento
WHISPER_MODEL=medium

# Idioma forzado para Whisper (opcional, déjalo vacío para autodetección)
# Ejemplos: es, en, pt, fr
WHISPER_LANGUAGE=

# ---------------------------------------------------------------------
# Groq (transcripción en la nube, opcional)
# ---------------------------------------------------------------------
# Obtén tu clave gratis en: https://console.groq.com/
# El tier gratuito permite miles de minutos de transcripción al día.
GROQ_API_KEY=tu_clave_de_groq_aqui

# Modelo de Whisper en Groq. Opciones:
# - whisper-large-v3       (mejor calidad, recomendado)
# - whisper-large-v3-turbo (más rápido, ligeramente menos preciso)
GROQ_WHISPER_MODEL=whisper-large-v3

# ---------------------------------------------------------------------
# Configuración de Claude (cuando LLM_PROVIDER=claude)
# ---------------------------------------------------------------------
# Número de frames a extraer para análisis multimodal con Claude
# (solo aplica cuando LLM_PROVIDER=claude, ya que Claude no procesa video nativo)
CLAUDE_VIDEO_FRAMES=12
